# ─────────────────────────────────────────────────────────────
# Template du .env de la stack MONITORING
# (à copier en /opt/monitoring/.env sur le VPS)
#
#   cp .env.monitoring.example .env   puis remplir les valeurs.
#   NE JAMAIS committer le .env réel (secrets Grafana).
# ─────────────────────────────────────────────────────────────

# --- Compte admin Grafana (créé au 1er démarrage) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_mot_de_passe_fort

# --- Connexion du postgres-exporter à la base de l'app (app_db) ---
# Idéalement un rôle PostgreSQL en LECTURE SEULE dédié au monitoring.
# Hôte = nom du conteneur DB sur le réseau app-network. sslmode=disable
# (trafic interne au réseau Docker).
#   postgresql://<user>:<password>@app_db:5432/<database>?sslmode=disable
DATA_SOURCE_NAME=postgresql://user:CHANGE_ME@app_db:5432/laravel?sslmode=disable
