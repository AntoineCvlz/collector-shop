# ─────────────────────────────────────────────────────────────
# RÉFÉRENCE des variables du .env de la stack MONITORING.
#
# ⚠️ En production, monitoring/.env est GÉNÉRÉ AUTOMATIQUEMENT par
# .github/workflows/deploy.yml depuis les secrets GitHub (GF_SECURITY_ADMIN_*,
# MONITORING_DATA_SOURCE_NAME). Ne pas le remplir à la main sur le VPS : il
# serait écrasé au prochain déploiement. Ce fichier documente les variables
# attendues (valeurs ci-dessous = placeholders bidon).
#
# NE JAMAIS committer un .env réel (secrets Grafana).
# ─────────────────────────────────────────────────────────────

# --- Compte admin Grafana (créé au 1er démarrage) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# --- Connexion du postgres-exporter à la base de l'app (app_db) ---
# Idéalement un rôle PostgreSQL en LECTURE SEULE dédié au monitoring.
# Hôte = nom du conteneur DB sur le réseau app-network. sslmode=disable
# (trafic interne au réseau Docker).
#   postgresql://<user>:<password>@app_db:5432/<database>?sslmode=disable
DATA_SOURCE_NAME=postgresql://monitoring_user:changeme@app_db:5432/laravel?sslmode=disable

# --- Alerting Grafana ---
# L'envoi SMTP par email n'est PAS configuré : les alertes se déclenchent et
# restent visibles dans l'UI Alerting de Grafana, mais ne partent pas par mail.
# Seul le destinataire est requis (interpolé dans contact-points.yaml via
# $__env{} — DOIT être non-vide sinon Grafana refuse de démarrer).
GF_ALERT_EMAIL_TO=alerts@example.invalid
