# ─────────────────────────────────────────────────────────────
# Template du .env de PRODUCTION (à copier en /opt/collector-shop/.env sur le VPS)
#
#   cp .env.prod.example .env   puis remplir les valeurs.
#   NE JAMAIS committer le .env réel (secrets).
# ─────────────────────────────────────────────────────────────

# --- Images Docker Hub (publiées par la CI) ---
DOCKERHUB_USERNAME=ton_user_dockerhub
BACKEND_IMAGE=collector-shop-back        # = vars.DEPLOY_APPLI_NAME
FRONTEND_IMAGE=collector-shop-front      # = vars.DEPLOY_APPLI_NAME_FRONT
IMAGE_TAG=latest

# --- Réseau ---
APP_PORT=80

# --- Application Laravel ---
APP_NAME=CollectorShop
APP_ENV=production
APP_DEBUG=false
# Générer avec :  docker run --rm IMAGE php artisan key:generate --show
APP_KEY=
APP_URL=http://87.106.171.146
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

# --- Base de données (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=collector_shop
DB_USERNAME=collector
DB_PASSWORD=CHANGE_ME_mot_de_passe_fort

# --- Sessions / cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning
