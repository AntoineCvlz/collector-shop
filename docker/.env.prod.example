# ─────────────────────────────────────────────────────────────
# RÉFÉRENCE des variables du .env de PRODUCTION.
#
# ⚠️ NE PAS remplir/copier ce fichier à la main sur le VPS : depuis la mise en
# place du déploiement CI, /opt/collector-shop/.env est GÉNÉRÉ AUTOMATIQUEMENT
# par .github/workflows/deploy.yml à chaque déploiement, depuis les secrets et
# variables GitHub (environnement "production"). Toute édition manuelle du .env
# sur le VPS sera ÉCRASÉE au prochain déploiement.
#
# Ce fichier ne sert plus que de documentation lisible des variables attendues.
# Pour changer une valeur en prod → modifier le secret/var GitHub correspondant :
#   APP_KEY      → secret LARAVEL_APP_KEY
#   DB_PASSWORD  → secret DB_PASSWORD
#   APP_URL      → variable PRODUCTION_URL
#   (constantes APP_ENV, DB_DATABASE… sont en dur dans deploy.yml)
#
# NE JAMAIS committer un .env réel (secrets).
# ─────────────────────────────────────────────────────────────

# --- Images Docker Hub (publiées par la CI) ---
DOCKERHUB_USERNAME=your-dockerhub-username
BACKEND_IMAGE=collector-shop-back        # = vars.DEPLOY_APPLI_NAME
FRONTEND_IMAGE=collector-shop-front      # = vars.DEPLOY_APPLI_NAME_FRONT
IMAGE_TAG=latest

# --- Réseau ---
APP_PORT=80

# --- Application Laravel ---
APP_NAME=CollectorShop
APP_ENV=production
APP_DEBUG=false
# Générer avec :  docker run --rm IMAGE php artisan key:generate --show
APP_KEY=
APP_URL=https://your-domain.example.com
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

# --- Base de données (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=collector_shop
DB_USERNAME=collector
DB_PASSWORD=changeme

# --- Sessions / cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning
