
DOCKERHUB_USERNAME=your-dockerhub-username
BACKEND_IMAGE=collector-shop-back        # = vars.DEPLOY_APPLI_NAME
FRONTEND_IMAGE=collector-shop-front      # = vars.DEPLOY_APPLI_NAME_FRONT
IMAGE_TAG=latest

APP_PORT=80

APP_NAME=CollectorShop
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-domain.example.com
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=collector_shop
DB_USERNAME=collector
DB_PASSWORD=changeme

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

LOG_CHANNEL=stderr
LOG_LEVEL=warning
